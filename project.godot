; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited via script.

[application]

config/name="The Ghost - 3D Multiplayer Horror"
config/description="A 3D multiplayer horror game inspired by The Ghost"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.3", "Mobile")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/game_manager.gd"
NetworkManager="*res://scripts/network_manager.gd"
AmbientSound="*res://scripts/ambient_sound.gd"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=0

[input]

move_forward={
